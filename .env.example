# SmartReview environment variables
#
# Usage (PowerShell):
#   Copy this file to .env and load it with your shell/tooling, OR set variables directly:
#     $env:DEEPSEEK_API_KEY = "..."
#
# Notes:
# - DeepSeek is required for MCQ generation and text chat.
# - Gemini is only required for image chat (PPT slide screenshots).

# --- DeepSeek (text LLM) ---
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Gemini (multimodal images) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# --- Limits ---
SMARTREVIEW_MAX_PDF_MB=25
SMARTREVIEW_MAX_IMAGE_MB=10
SMARTREVIEW_MAX_CONTEXT_CHARS=120000
SMARTREVIEW_MAX_GENERATED_QUESTIONS=50

# --- Defaults ---
SMARTREVIEW_DEFAULT_CHAPTER_TITLE=General
