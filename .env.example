# SmartReview environment variables
#
# Quick start:
#   1. Copy this file to .env:  cp .env.example .env
#   2. Fill in your API keys below.
#   3. Start the server as usual:  python -m uvicorn smartreview_api:app --reload --port 8000
#
# The backend auto-loads .env via python-dotenv.
# .env is in .gitignore — it will never be committed.
#
# Notes:
# - DeepSeek is required for MCQ generation and text chat.
# - Gemini is only required for image chat (PPT slide screenshots).

# --- DeepSeek (text LLM) ---
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Gemini (multimodal images) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# --- Limits ---
SMARTREVIEW_MAX_PDF_MB=25
SMARTREVIEW_MAX_IMAGE_MB=10
SMARTREVIEW_MAX_CONTEXT_CHARS=120000
SMARTREVIEW_MAX_GENERATED_QUESTIONS=50

# --- Defaults ---
SMARTREVIEW_DEFAULT_CHAPTER_TITLE=General
